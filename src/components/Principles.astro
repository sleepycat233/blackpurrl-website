<section class="px-6 py-section sm:py-section-lg bg-white text-black">
  <div class="section-container text-center">
    <h2 class="section-title">Our principles</h2>
    <div class="mt-14 grid gap-6 sm:gap-8 md:grid-cols-3">
      <div class="card-light">
        <div class="glyph-light mb-4 mx-auto">*</div>
        <h3 class="text-xl font-semibold text-black">Open source, open-weight, community efforts, forever.</h3>
        <p class="mt-3 text-ink-500 leading-relaxed">
          No bait-and-switch. The code is public, the builds are reproducible, and it stays that way.
        </p>
      </div>
      <div class="card-light">
        <div class="glyph-light mb-4 mx-auto">=</div>
        <h3 class="text-xl font-semibold text-black">Model-agnostic.</h3>
        <p class="mt-3 text-ink-500 leading-relaxed">
          Bring your own model, bring your own key. No vendor lock-in, no subscription required.
        </p>
      </div>
      <div class="card-light">
        <div class="glyph-light mb-4 mx-auto">~</div>
        <h3 class="text-xl font-semibold text-black">Your memory, your data.</h3>
        <p class="mt-3 text-ink-500 leading-relaxed">
          Every session, every knowledge base entry stays local and exportable. We never see it.
        </p>
      </div>
    </div>
  </div>
</section>