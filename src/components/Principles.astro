<section class="px-6 py-section sm:py-section-lg bg-black text-white">
  <div class="section-container text-center">
    <h2 class="section-title">Our principles</h2>
    <div class="mt-14 grid gap-6 sm:gap-8 md:grid-cols-3">
      <div class="card-dark">
        <div class="w-10 h-10 rounded-lg border border-gray-700 text-gray-300 flex items-center justify-center text-sm mb-4 font-mono">*</div>
        <h3 class="text-xl font-semibold text-white">Open source, forever.</h3>
        <p class="mt-3 text-gray-400 leading-relaxed">
          No bait-and-switch. The code is public, the builds are reproducible, and it stays that way.
        </p>
      </div>
      <div class="card-dark">
        <div class="w-10 h-10 rounded-lg border border-gray-700 text-gray-300 flex items-center justify-center text-sm mb-4 font-mono">=</div>
        <h3 class="text-xl font-semibold text-white">Model-agnostic.</h3>
        <p class="mt-3 text-gray-400 leading-relaxed">
          Bring your own model, bring your own key. No vendor lock-in, no subscription required.
        </p>
      </div>
      <div class="card-dark">
        <div class="w-10 h-10 rounded-lg border border-gray-700 text-gray-300 flex items-center justify-center text-sm mb-4 font-mono">~</div>
        <h3 class="text-xl font-semibold text-white">Your memory, your data.</h3>
        <p class="mt-3 text-gray-400 leading-relaxed">
          Every session, every knowledge base entry stays local and exportable. We never see it.
        </p>
      </div>
    </div>
  </div>
</section>
