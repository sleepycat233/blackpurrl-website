<section class="px-6 py-section sm:py-section-lg bg-white text-black">
  <div class="section-container">
    <h2 class="section-title text-center">Core capabilities</h2>
    <div class="mt-14 grid gap-6 sm:gap-8 md:grid-cols-2">
      <div class="card-light">
        <div class="w-10 h-10 rounded-lg bg-black text-white flex items-center justify-center text-sm mb-4">⌨️</div>
        <h3 class="text-xl font-semibold">One hotkey, zero alt-tab</h3>
        <p class="mt-3 text-gray-600 leading-relaxed">
          Ask without ever leaving the game. Press a hotkey, speak your question, get an answer — no window switching required.
        </p>
      </div>
      <div class="card-light">
        <div class="w-10 h-10 rounded-lg bg-black text-white flex items-center justify-center text-sm mb-4">🎮</div>
        <h3 class="text-xl font-semibold">Reads your real game state</h3>
        <p class="mt-3 text-gray-600 leading-relaxed">
          Current quest, stage, location, and NPC — read live from the game's memory, not guessed from a screenshot.
        </p>
      </div>
      <div class="card-light">
        <div class="w-10 h-10 rounded-lg bg-black text-white flex items-center justify-center text-sm mb-4">📚</div>
        <h3 class="text-xl font-semibold">Grounded, not hallucinated</h3>
        <p class="mt-3 text-gray-600 leading-relaxed">
          A local knowledge base built from game wikis and guides. Answers are grounded in real lore, not made up.
        </p>
      </div>
      <div class="card-light">
        <div class="w-10 h-10 rounded-lg bg-black text-white flex items-center justify-center text-sm mb-4">🚫</div>
        <h3 class="text-xl font-semibold">Spoiler-aware</h3>
        <p class="mt-3 text-gray-600 leading-relaxed">
          Explains what's happening now without ruining what's next. You control how much information you want.
        </p>
      </div>
    </div>
  </div>
</section>
