---
import { scenarios } from '../data/scenarios';
---

<section class="px-6 md:px-8 lg:px-12 min-h-[100dvh] flex flex-col justify-start md:justify-center bg-black text-white">
  <div class="max-w-7xl mx-auto w-full pt-[calc(3.5rem+0.75rem)] pb-4 sm:pt-[calc(3.5rem+1.5rem)] sm:pb-6 lg:pt-[calc(3.5rem+2rem)] lg:pb-8">

    <div class="md:flex md:items-center md:gap-8 lg:gap-12">

    <!-- left column -->
    <div class="md:w-2/5 md:text-left text-center flex flex-col">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        <span class="text-white">Your companion through</span><br>
        <!-- rotating lines: narrow = slot-machine dial, wide = stacked relay -->
        <span class="hero-dial mt-1 md:block md:text-left">
          <span class="hero-dial-track" data-dial-track>
            <button data-tab="0" class="hero-tab block w-full md:text-left text-center cursor-pointer bg-transparent border-0 p-0">
              <span class="hero-tab-text" style="background-image: linear-gradient(to right, #a78bfa 50%, #4b5563 50%); background-size: 200% 100%; background-position: 100% 0; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">every quest,</span>
            </button>
            <button data-tab="1" class="hero-tab block w-full md:text-left text-center cursor-pointer bg-transparent border-0 p-0">
              <span class="hero-tab-text" style="background-image: linear-gradient(to right, #a78bfa 50%, #4b5563 50%); background-size: 200% 100%; background-position: 100% 0; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">every world,</span>
            </button>
            <button data-tab="2" class="hero-tab block w-full md:text-left text-center cursor-pointer bg-transparent border-0 p-0">
              <span class="hero-tab-text" style="background-image: linear-gradient(to right, #a78bfa 50%, #4b5563 50%); background-size: 200% 100%; background-position: 100% 0; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent;">every moment.</span>
            </button>
          </span>
        </span>
      </h1>

      <p class="mt-6 text-base sm:text-lg text-ink-200 max-w-2xl text-pretty leading-relaxed hidden md:block">
        BlackPurrl is your AI companion for the games you play. Ask anything — it answers from where you are, right now.
      </p>
    </div>

    <!-- right column: real-time voice-interaction "promo clip" -->
    <div class="mt-3 md:mt-0 md:w-3/5">
      <div class="hero-clip-frame">
        <!-- A. scene layer: clean 16:9 game picture (avatar/voice/mute only) -->
        <div class="hero-clip-stage">
          {scenarios.map((scenario, i) => (
            <div
              data-panel={i}
              class="hero-clip-scene"
              style={`--scene-hue: ${250 - i * 40}deg; ${i === 0 ? 'opacity: 1;' : 'opacity: 0; pointer-events: none;'}`}
            >
              <!-- scene background -->
              <video
                class="hero-clip-bg"
                src={`/video/scene-${i}.mp4`}
                autoplay
                loop
                muted
                playsinline
                aria-hidden="true"
              />
              <div class="hero-clip-scrim" aria-hidden="true"></div>

              <!-- virtual avatar (placeholder mascot) + voice bars + mute -->
              <div class="hero-clip-avatar">
                <div class="voice-bars" data-bars aria-hidden="true">
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
                <img src="/brand/white-cat-mascot.png" alt="" width="112" height="112" loading="eager" />
              </div>
              <button
                type="button"
                class="hero-clip-mute"
                data-mute
                data-audio={`/audio/${scenario.id}.mp3`}
                aria-label="Audio muted — voice playback coming soon"
                title="Voice playback coming soon"
              >🔊</button>
            </div>
          ))}
        </div>

        <!-- B. dialogue track: all spoken subtitles, BELOW the picture -->
        <div class="hero-clip-track">
          {scenarios.map((scenario, i) => (
            <div
              data-track={i}
              data-question={scenario.question}
              data-toolcall={scenario.toolCall}
              data-statelabel={scenario.stateLabel}
              data-statepills={scenario.statePills.join('|')}
              data-answer={scenario.answer}
              class={`hero-clip-lines${i === 0 ? ' is-active' : ''}`}
            >
              <p class="clip-line clip-line-you" data-you-line>
                <span class="clip-speaker">You</span>
                <span class="clip-text" data-you></span>
              </p>
              <div class="clip-line clip-line-bp" data-bp-line>
                <span class="clip-speaker clip-speaker-ai">Companion</span>
                <span class="clip-bp-body">
                  <span class="clip-bp-thinking" data-tool>
                    <span class="clip-bp-tag">thinking</span>
                    <span class="clip-text clip-text-tool" data-tool-text></span>
                  </span>
                  <span class="clip-bp-state" data-state>
                    <span class="clip-bp-tag" data-state-label></span>
                    <span class="clip-state-pills" data-state-text></span>
                  </span>
                  <span class="clip-bp-voice" data-ai>
                    <span class="clip-bp-tag clip-voice-bars-wrap" aria-hidden="true">
                      <span class="clip-voice-bars"><span></span><span></span><span></span><span></span><span></span><span></span></span>
                    </span>
                    <span class="clip-text" data-ai-text></span>
                  </span>
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    </div>
  </div>
</section>

<script>
  const TOOL_AT_CONST  = 500;
  const STATE_AT_CONST = 1200;
  const SPEAK_AT_CONST = 2000;
  const TYPE_BUDGET_CONST = 4000;
  const READ_PAUSE_CONST  = 2000;
  const DURATION = SPEAK_AT_CONST + TYPE_BUDGET_CONST + READ_PAUSE_CONST; // 8000

  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.hero-tab'));
  const scenes = Array.from(document.querySelectorAll<HTMLElement>('.hero-clip-scene'));
  const tracks = Array.from(document.querySelectorAll<HTMLElement>('.hero-clip-lines'));
  const spans = Array.from(document.querySelectorAll<HTMLElement>('.hero-tab-text'));
  const dialTrack = document.querySelector<HTMLElement>('[data-dial-track]');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const narrowQuery = window.matchMedia('(max-width: 767px)');
  const DIAL_ROLL_MS = 300; // matches .hero-dial-track transition

  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let rafId: number | null = null;
  let startTime: number | null = null;
  let captionTimers: ReturnType<typeof setTimeout>[] = [];
  let fillTimer: ReturnType<typeof setTimeout> | null = null;

  // ── left column: text-fill rotation (unchanged behaviour) ──────────
  function resetSpan(span: HTMLElement) {
    // keep CSS transition on → previous line's fill fades back smoothly (hand-off)
    span.style.transition = '';
    span.style.backgroundPosition = '100% 0';
  }

  function activateTab(index: number) {
    scenes.forEach((scene, i) => {
      scene.style.opacity = i === index ? '1' : '0';
      scene.style.pointerEvents = i === index ? 'auto' : 'none';
    });
    tracks.forEach((track, i) => {
      track.classList.toggle('is-active', i === index);
    });
    spans.forEach((span, i) => {
      if (i !== index) resetSpan(span);
    });
    tabs.forEach((tab, i) => tab.classList.toggle('is-active', i === index));
  }

  function animateFill(spanIndex: number, duration: number) {
    if (rafId) cancelAnimationFrame(rafId);
    startTime = null;
    const span = spans[spanIndex];
    if (reduceMotion) {
      span.style.backgroundPosition = '0% 0'; // jump to final (fully violet)
      return;
    }
    // RAF drives background-position per frame → disable CSS transition so it
    // isn't smeared; resetSpan() re-enables it for the smooth hand-off.
    span.style.transition = 'none';
    span.style.backgroundPosition = '100% 0';
    function step(ts: number) {
      if (!startTime) startTime = ts;
      const elapsed = ts - startTime;
      const pct = Math.max(100 - (elapsed / duration) * 100, 0);
      span.style.backgroundPosition = `${pct}% 0`;
      if (pct > 0) rafId = requestAnimationFrame(step);
    }
    rafId = requestAnimationFrame(step);
  }

  // ── right column: voice-clip turn-taking + typewriter captions ─────
  function clearCaptionTimers() {
    captionTimers.forEach(clearTimeout);
    captionTimers = [];
    if (fillTimer) { clearTimeout(fillTimer); fillTimer = null; }
  }

  function typewriter(el: HTMLElement, text: string, perWord: number, onDone?: () => void) {
    if (reduceMotion) {
      el.textContent = text;
      onDone?.();
      return;
    }
    const words = text.split(' ');
    let i = 0;
    function tick() {
      el.textContent = words.slice(0, i).join(' ');
      if (i < words.length) {
        i += 1;
        captionTimers.push(setTimeout(tick, perWord));
      } else {
        onDone?.();
      }
    }
    tick();
  }

  function playClip(index: number) {
    clearCaptionTimers();
    const scene = scenes[index];
    const track = tracks[index];
    const youText  = track.querySelector<HTMLElement>('[data-you]');
    const toolText = track.querySelector<HTMLElement>('[data-tool-text]');
    const stateText = track.querySelector<HTMLElement>('[data-state-text]');
    const aiText   = track.querySelector<HTMLElement>('[data-ai-text]');
    if (!youText || !toolText || !stateText || !aiText) return;

    const question   = track.dataset.question ?? '';
    const toolCall   = track.dataset.toolcall ?? '';
    const stateLabel = track.dataset.statelabel ?? 'game state';
    const statePills = (track.dataset.statepills ?? '').split('|').filter(Boolean);
    const answer     = track.dataset.answer ?? '';
    const stateLabelEl = track.querySelector<HTMLElement>('[data-state-label]');

    // reset
    scenes.forEach((s) => {
      s.classList.remove('is-speaking');
    });
    tracks.forEach((t) => {
      t.classList.remove('you-active', 'bp-thinking', 'bp-state', 'bp-voice', 'is-typing');
      // keep is-active — that's managed by activateTab
      t.querySelectorAll<HTMLElement>('[data-you], [data-tool-text], [data-state-text], [data-ai-text]')
        .forEach((el) => (el.textContent = ''));
    });

    // restart video from frame 0 so video + dialogue stay in sync
    const video = scene.querySelector<HTMLVideoElement>('video');
    if (video) { video.currentTime = 0; video.play().catch(() => {}); }

    // 0ms — You question
    track.classList.add('you-active');
    youText.textContent = question;

    const TOOL_AT     = TOOL_AT_CONST;
    const STATE_AT    = STATE_AT_CONST;
    const SPEAK_AT    = SPEAK_AT_CONST;
    const TYPE_BUDGET = TYPE_BUDGET_CONST;
    const READ_PAUSE  = READ_PAUSE_CONST;

    // step 2 — BlackPurrl thinking
    captionTimers.push(setTimeout(() => {
      track.classList.add('bp-thinking');
      toolText.textContent = toolCall;
    }, TOOL_AT));

    // step 3 — BlackPurrl game state pills
    captionTimers.push(setTimeout(() => {
      track.classList.add('bp-state');
      if (stateLabelEl) stateLabelEl.textContent = stateLabel;
      stateText.innerHTML = '';
      statePills.forEach((pill) => {
        const s = document.createElement('span');
        s.className = 'state-pill';
        s.textContent = pill;
        stateText.appendChild(s);
      });
    }, STATE_AT));

    // step 4 — BlackPurrl voice answer
    captionTimers.push(setTimeout(() => {
      track.classList.add('bp-voice', 'is-typing');
      scene.classList.add('is-speaking');
      const wordCount = answer.split(' ').length;
      const perWord = Math.min(TYPE_BUDGET / Math.max(wordCount, 1), 120);
      typewriter(aiText, answer, perWord, () => {
        track.classList.remove('is-typing');
        scene.classList.remove('is-speaking');
        if (timer) { clearInterval(timer); clearTimeout(timer as unknown as ReturnType<typeof setTimeout>); }
        timer = setTimeout(advance, READ_PAUSE) as unknown as ReturnType<typeof setInterval>;
      });
    }, SPEAK_AT));
  }

  // ── shared rotation clock — driven by typewriter onDone, not a fixed interval ──
  function goTo(index: number) {
    current = index;
    if (timer) { clearInterval(timer); clearTimeout(timer as unknown as ReturnType<typeof setTimeout>); }
    activateTab(index);
    // narrow screens: roll the slot-machine dial to this line
    if (dialTrack) {
      dialTrack.style.transform = `translateY(calc(-${index} * 1.4em))`;
    }
    // compute actual cycle duration for this scene's answer length
    const answer = tracks[index]?.dataset.answer ?? '';
    const wordCount = answer.split(' ').length;
    const perWord = Math.min(TYPE_BUDGET_CONST / Math.max(wordCount, 1), 120);
    const cycleDuration = SPEAK_AT_CONST + (wordCount * perWord) + READ_PAUSE_CONST;
    // playClip calls clearCaptionTimers internally, so schedule animateFill AFTER it
    playClip(index);
    // narrow: let the dial roll settle (300ms) before the progress bar wipes.
    // fillTimer is cleared by clearCaptionTimers so rapid clicks stay clean.
    if (fillTimer) clearTimeout(fillTimer);
    if (narrowQuery.matches && !reduceMotion) {
      fillTimer = setTimeout(() => animateFill(index, cycleDuration), DIAL_ROLL_MS);
    } else {
      animateFill(index, cycleDuration);
    }
  }

  function advance() {
    goTo((current + 1) % tabs.length);
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => goTo(i));
  });

  // mute toggle stub — no audio wired yet
  document.querySelectorAll<HTMLButtonElement>('[data-mute]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const muted = btn.dataset.muted !== 'false';
      btn.dataset.muted = muted ? 'false' : 'true';
      btn.textContent = muted ? '🔈' : '🔊';
      btn.setAttribute('aria-label', muted ? 'Audio on (demo coming soon)' : 'Audio muted');
      // future: new Audio(btn.dataset.audio ?? '').play();
    });
  });

  // kick off
  goTo(0);
</script>
