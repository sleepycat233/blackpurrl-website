---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'BlackPurrl — Your companion through every quest, every world, every moment.', description = 'BlackPurrl is your AI companion for the games you play. Ask anything — it answers from where you are, right now.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-black text-white antialiased">
    <main>
      <slot />
    </main>
  </body>
</html>